# Copy to .env.e2e.real-site on the backend host.
# .env.* files are ignored by git.

# Backend Docker Compose file, relative to the repo root.
COMPOSE_FILE=docker-compose.backend-only.yml

# Deployed Vercel frontend under test.
PLAYWRIGHT_BASE_URL=https://yudai.app

# Direct API calls made by Playwright helpers. On the backend host this should
# target the local Docker-published backend, while the browser still opens Vercel.
PLAYWRIGHT_API_BASE_URL=http://localhost:8000

# Optional: choose a backend user with an active GitHub OAuth token. If omitted,
# the launcher uses the most recently updated backend user with an active token.
E2E_USERNAME=

# Repository and branch visible to the chosen backend user.
E2E_REPO_OWNER=pranay5255
E2E_REPO_NAME=YudaiV3
E2E_REPO_BRANCH=main

# Set to 1 to mock repository, branch, and issue-list responses from the env
# values. Auth, session, execution, and question APIs still hit the backend.
E2E_MOCK_REPOSITORY_API=1

# Fresh Yudai session tokens are minted per run inside the backend container.
E2E_SESSION_TOKEN_HOURS=2

# Set to 1 after Chromium is already installed on the server.
E2E_SKIP_PLAYWRIGHT_INSTALL=0
