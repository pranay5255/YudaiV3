# ===========================================
# YudaiV3 Deployment Environment Template
# Copy to .env.deploy and fill in values
# ===========================================

# ===========================================
# DEPLOYMENT MODE
# ===========================================
# nginx: Backend behind nginx with SSL at api.yudai.app
# direct: Vercel rewrites /api to backend IP
DEPLOY_MODE=nginx

# ===========================================
# DOMAIN CONFIGURATION
# ===========================================
FRONTEND_DOMAIN=yudai.app
BACKEND_DOMAIN=api.yudai.app

# Backend IP (required for direct mode)
BACKEND_IP=139.84.154.9

# ===========================================
# SSL CONFIGURATION (nginx mode)
# ===========================================
SSL_EMAIL=admin@yudai.app

# ===========================================
# VERCEL CONFIGURATION
# ===========================================
# Get from Vercel dashboard -> Settings -> General
VERCEL_ORG_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx

# Or use Vercel CLI (vercel login) instead
# VERCEL_TOKEN=xxx

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================
# Set these in Vercel dashboard or via CLI

# nginx mode: Full URL to backend API
VITE_API_BASE_URL=https://api.yudai.app

# direct mode: Use Vercel rewrite
# VITE_API_BASE_URL=/api

# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================
# These should be set in backend/.env.prod

# CORS - Comma-separated allowed origins
ALLOW_ORIGINS=https://yudai.app

# URLs
FRONTEND_URL=https://yudai.app
BACKEND_URL=https://api.yudai.app

# GitHub OAuth redirect
GITHUB_REDIRECT_URI=https://yudai.app/auth/callback

# ===========================================
# DNS CONFIGURATION
# ===========================================
# Frontend (Vercel):
#   A Record: yudai.app -> 76.76.21.21
#   or CNAME: yudai.app -> cname.vercel-dns.com
#
# Backend (nginx mode):
#   A Record: api.yudai.app -> YOUR_SERVER_IP
#
# Backend (direct mode):
#   No DNS needed - accessed via Vercel rewrite
