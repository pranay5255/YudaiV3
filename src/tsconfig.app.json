{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./*"],
      "remotion": ["./node_modules/remotion/dist/cjs/index.d.ts"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": [
    "api",
    "dist",
    "e2e",
    "node_modules",
    "playwright.config.ts",
    "tests/frontend/vercelMiddleware.test.ts"
  ]
}
