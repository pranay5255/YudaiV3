{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/auth/api/:path*",
      "destination": "https://api.yudai.app/auth/api/:path*"
    },
    {
      "source": "/ai/:path*",
      "destination": "/api/ai/:path*"
    },
    {
      "source": "/daifu/:path*",
      "destination": "https://api.yudai.app/daifu/:path*"
    },
    {
      "source": "/github/:path*",
      "destination": "https://api.yudai.app/github/:path*"
    },
    {
      "source": "/controller/:path*",
      "destination": "https://api.yudai.app/controller/:path*"
    },
    {
      "source": "/realtime/:path*",
      "destination": "/api/realtime/:path*"
    },
    {
      "source": "/((?!api/|ai/|daifu/|github/|controller/|realtime/|auth/api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
